// CP System - Prisma schema (PostgreSQL)
// See docs/DESIGN_SYSTEM.md §5 for entity definitions

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  Active
  Paused
  Exited
}

enum InquiryStatus {
  New
  Contacted
  Converted
}

enum AttendeeType {
  Member
  Guest
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?  @map("password_hash")
  name         String
  phone        String?
  isSuperAdmin  Boolean    @default(false) @map("is_super_admin")
  status        UserStatus @default(Active)
  deactivatedAt DateTime?  @map("deactivated_at")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  memberProfile        MemberProfile?
  mentorOf             MemberProfile[]     @relation("Mentor")
  userModuleAssignments UserModuleAssignment[]
  memberWorkgroupHistory MemberWorkgroupHistory[]
  financialTransactions FinancialTransaction[]
  payments             Payment[]           @relation("PaymentMember")
  paymentsCreated      Payment[]           @relation("PaymentCreatedBy")
  paymentsVerified     Payment[]           @relation("PaymentVerifiedBy")
  eventAttendances     EventAttendance[]
  eventsCreated        Event[]             @relation("EventCreatedBy")
  eventsContactPerson  Event[]             @relation("EventContactPerson")
  expenses             Expense[]
  budgetForecasts      BudgetForecast[]
  pastEventAttachments PastEventAttachment[]
  notificationLogs     NotificationLog[]
  actionedInquiries    MembershipInquiry[]
  downloadableDocuments DownloadableDocument[]
  financialAccounts    FinancialAccount[]
  attendanceRecordedBy  EventAttendance[]   @relation("AttendanceRecordedBy")
  workgroupHistoryRecorded MemberWorkgroupHistory[] @relation("WorkgroupHistoryRecordedBy")
  moduleAssignmentsGiven UserModuleAssignment[] @relation("AssignmentsGivenBy")
}

model Workgroup {
  id           String   @id @default(cuid())
  name         String
  abbreviation String   @unique // COR | SPIRI | TB
  status       String   @default("active") // active | inactive
  description  String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  memberProfiles          MemberProfile[]
  memberWorkgroupHistory  MemberWorkgroupHistory[]
  events                  Event[]
}

model MemberProfile {
  userId        String    @id @map("user_id")
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workgroupId   String    @map("workgroup_id")
  workgroup     Workgroup @relation(fields: [workgroupId], references: [id])
  joinDate      DateTime  @map("join_date")
  mentorId      String?   @map("mentor_id")
  mentor        User?     @relation("Mentor", fields: [mentorId], references: [id])
  preferredName String?   @map("preferred_name")
}

model MemberWorkgroupHistory {
  id            String    @id @default(cuid())
  memberId      String    @map("member_id")
  member        User      @relation(fields: [memberId], references: [id], onDelete: Cascade)
  workgroupId   String    @map("workgroup_id")
  workgroup     Workgroup @relation(fields: [workgroupId], references: [id])
  effectiveFrom DateTime  @map("effective_from")
  effectiveTo   DateTime? @map("effective_to") // null = current
  recordedById  String?   @map("recorded_by_id")
  recordedBy    User?    @relation("WorkgroupHistoryRecordedBy", fields: [recordedById], references: [id])
  recordedAt    DateTime  @default(now()) @map("recorded_at")
}

model Module {
  id          String   @id @default(cuid())
  code        String   @unique // PersonalDashboard, GroupWideReports, Finance, etc.
  name        String
  description String?

  userModuleAssignments UserModuleAssignment[]
}

model UserModuleAssignment {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  moduleId  String    @map("module_id")
  module    Module    @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  canView   Boolean   @default(false) @map("can_view")
  canCreate Boolean   @default(false) @map("can_create")
  canEdit   Boolean   @default(false) @map("can_edit")
  canDelete Boolean   @default(false) @map("can_delete")
  validFrom DateTime? @map("valid_from")
  validUntil DateTime? @map("valid_until") // for temporary e.g. Events
  assignedById String? @map("assigned_by_id")
  assignedBy   User?   @relation("AssignmentsGivenBy", fields: [assignedById], references: [id])
  assignedAt   DateTime @default(now()) @map("assigned_at")

  @@unique([userId, moduleId])
}

model FinancialAccount {
  id            String   @id @default(cuid())
  memberId      String   @map("member_id")
  member        User     @relation(fields: [memberId], references: [id], onDelete: Cascade)
  type          String   // CP_KITTY_ANNUAL | CP_KITTY_MONTHLY | WELFARE_MONTHLY | MANUAL_CP_KITTY | MANUAL_WELFARE
  yearOrMonth   String   @map("year_or_month")
  amountExpected Decimal @map("amount_expected") @db.Decimal(12, 2)
  amountPaid    Decimal  @default(0) @map("amount_paid") @db.Decimal(12, 2)
  dueDate       DateTime? @map("due_date")
  notes         String?
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([memberId, type, yearOrMonth])
}

model FinancialTransaction {
  id             String   @id @default(cuid())
  memberId       String   @map("member_id")
  member         User     @relation(fields: [memberId], references: [id], onDelete: Cascade)
  accountType    String   @map("account_type") // CP-KITTY | CP-Welfare
  amount         Decimal  @db.Decimal(12, 2)
  transactionDate DateTime @map("transaction_date")
  sourceFileId   String?  @map("source_file_id")
  importBatchId  String?  @map("import_batch_id")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("Transaction")
}

model PaymentAccount {
  id          String   @id @default(cuid())
  code        String   @unique // CP-KITTY | CP-WELFARE
  name        String
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  payments    Payment[]
}

model Payment {
  id           String   @id @default(cuid())
  mpesaCode    String   @map("mpesa_code")
  datePaid     DateTime @map("date_paid") @db.Date
  amount       Decimal  @db.Decimal(12, 2)
  accountId    String   @map("account_id")
  account      PaymentAccount @relation(fields: [accountId], references: [id], onDelete: Restrict)
  memberId     String   @map("member_id")
  member       User     @relation("PaymentMember", fields: [memberId], references: [id], onDelete: Cascade)
  payeeName    String   @map("payee_name")
  createdById  String?  @map("created_by_id")  // null = imported from report
  createdBy    User?    @relation("PaymentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  verified     Boolean  @default(false)
  verifiedById String?  @map("verified_by_id")
  verifiedBy   User?    @relation("PaymentVerifiedBy", fields: [verifiedById], references: [id], onDelete: SetNull)
  verifiedAt   DateTime? @map("verified_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
}

model Expense {
  id                String   @id @default(cuid())
  title             String?
  description       String
  amount            Decimal  @db.Decimal(12, 2)
  expenseDate       DateTime @map("expense_date")
  categoryOrAccount String?  @map("category_or_account") // CP-KITTY | Welfare | general
  recordedById      String   @map("recorded_by_id")
  recordedBy        User     @relation(fields: [recordedById], references: [id])
  createdAt         DateTime @default(now()) @map("created_at")
}

model BudgetForecast {
  id               String    @id @default(cuid())
  title            String
  date             DateTime  @db.Date
  forecastAmount   Decimal   @map("forecast_amount") @db.Decimal(12, 2)
  notes            String?
  recordedById     String    @map("recorded_by_id")
  recordedBy       User      @relation(fields: [recordedById], references: [id])
  createdAt        DateTime  @default(now()) @map("created_at")
}

model Event {
  id                    String   @id @default(cuid())
  title                 String
  theme                 String?
  descriptionAgenda     String?   @map("description_agenda")
  date                  DateTime @db.Date
  startTime             String?   @map("start_time") // optional time
  imageBannerUrl        String?   @map("image_banner_url")
  venue                 String?
  workgroupAssignedId   String?   @map("workgroup_assigned_id")
  workgroupAssigned     Workgroup? @relation(fields: [workgroupAssignedId], references: [id])
  contactPersonId       String?   @map("contact_person_id")
  contactPerson         User?     @relation("EventContactPerson", fields: [contactPersonId], references: [id])
  reminderDays          String?   @map("reminder_days") // e.g. [7,1] JSON
  category              String    @default("CP_EVENT") // CP_EVENT | MGM | KACHAI
  featuredOnLanding     Boolean   @default(false) @map("featured_on_landing")
  postEventReportUrl    String?   @map("post_event_report_url")
  createdById           String?   @map("created_by_id")
  createdBy             User?     @relation("EventCreatedBy", fields: [createdById], references: [id])
  createdAt             DateTime @default(now()) @map("created_at")

  attendances         EventAttendance[]
  pastEventAttachments PastEventAttachment[]
}

model EventAttendance {
  id           String      @id @default(cuid())
  eventId      String      @map("event_id")
  event        Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  attendeeType AttendeeType @map("attendee_type")
  memberId     String?     @map("member_id")
  member       User?      @relation(fields: [memberId], references: [id], onDelete: SetNull)
  guestFullName String?   @map("guest_full_name")
  recordedById String?    @map("recorded_by_id")
  recordedBy   User?      @relation("AttendanceRecordedBy", fields: [recordedById], references: [id])
  recordedAt   DateTime   @default(now()) @map("recorded_at")
}

model PastEventAttachment {
  id        String   @id @default(cuid())
  eventId   String   @map("event_id")
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  type      String   // Report | Budget | AttendanceList | LessonsLearned
  fileUrlOrText String @map("file_url_or_text")
  uploadedById String? @map("uploaded_by_id")
  uploadedBy   User?   @relation(fields: [uploadedById], references: [id])
  uploadedAt   DateTime @default(now()) @map("uploaded_at")
}

model MembershipInquiry {
  id            String        @id @default(cuid())
  name          String
  contact       String
  email         String
  message       String        @db.Text
  submittedAt   DateTime      @default(now()) @map("submitted_at")
  status        InquiryStatus @default(New)
  notes         String?       @db.Text
  actionedById  String?       @map("actioned_by_id")
  actionedBy    User?         @relation(fields: [actionedById], references: [id])
  actionedAt    DateTime?     @map("actioned_at")
  createdAt     DateTime      @default(now()) @map("created_at")
}

model DownloadableDocument {
  id                 String   @id @default(cuid())
  title              String
  description        String?
  fileStoragePathOrUrl String  @map("file_storage_path_or_url")
  category           String?  // Constitution, Guidelines, Documentation
  sortOrder          Int?     @default(0) @map("sort_order")
  isActive           Boolean  @default(true) @map("is_active")
  createdById        String?  @map("created_by_id")
  createdBy          User?    @relation(fields: [createdById], references: [id])
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
}

model NotificationLog {
  id        String   @id @default(cuid())
  memberId  String   @map("member_id")
  member    User     @relation(fields: [memberId], references: [id], onDelete: Cascade)
  channel   String   // Email | WhatsApp
  templateId String? @map("template_id")
  sentAt    DateTime @default(now()) @map("sent_at")
  payload   String?  @db.Text // JSON
}

model ComplianceRun {
  id                      String   @id @default(cuid())
  runAt                   DateTime @map("run_at")
  membersChecked          Int      @map("members_checked")
  membersPaused           Int      @map("members_paused")
  membersRemovedFromChat  Int      @map("members_removed_from_chat")
  log                     String?  @db.Text // JSON
}

// Config / seed data - SystemConfig can be a key-value table or use env; Modules are seeded
model SystemConfig {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text
}
